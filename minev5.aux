\@writefile{lof}{\contentsline {figure}{\numberline {5-2}{\ignorespaces LIBERO-90上四种方法的定量对比。纯BT基线的VOC $r$极低（0.147），验证了单调性陷阱的存在；L2平滑有所改善但仍不充分（0.616）；本文方法以0.968大幅领先，甚至超越了使用帧级进度标签的有监督基线（0.860）。\relax }}{10}{figure.caption.7}\protected@file@percent }
